{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/hung/.codex/hooks/crg_session_start.py",
            "timeout": 30,
            "statusMessage": "Loading code-review-graph context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/hung/.codex/hooks/dedup.py",
            "timeout": 5,
            "statusMessage": "Checking duplicate tool call"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/hung/.codex/hooks/rtk_codex.py",
            "timeout": 10,
            "statusMessage": "Checking RTK rewrite"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir >/dev/null 2>&1 && code-review-graph update --skip-flows >/dev/null 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Updating code-review-graph"
          }
        ]
      }
    ]
  }
}
