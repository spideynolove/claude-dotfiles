{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/crg_session_start.py",
            "timeout": 30,
            "statusMessage": "Loading code-review-graph context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/crg_prompt_submit.py",
            "timeout": 10,
            "statusMessage": "Injecting code-review-graph change analysis"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/dedup.py",
            "timeout": 5,
            "statusMessage": "Checking duplicate tool call"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.codex/hooks/rtk_codex.py",
            "timeout": 10,
            "statusMessage": "Checking RTK rewrite"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git rev-parse --git-dir >/dev/null 2>&1 && CRG_BIN=\"${CODE_REVIEW_GRAPH_BIN:-$(command -v code-review-graph || echo \"$HOME/env/.venv/bin/code-review-graph\")}\" && \"$CRG_BIN\" update --skip-flows >/dev/null 2>&1 || true",
            "timeout": 30,
            "statusMessage": "Updating code-review-graph"
          }
        ]
      }
    ]
  }
}
